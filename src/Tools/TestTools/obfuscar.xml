<?xml version="1.0"?>
<Obfuscator>
  <!-- input and output folders (adjust to your build output) -->
  <Var name="InPath"  value="bin\Debug\net8.0" />
  <Var name="OutPath" value="bin\Debug\net8.0\obfuscated" />

  <!-- Global options -->
  <Var name="HideStrings" value="true" />
  <Var name="UseUnicodeNames" value="false" />
  <Var name="RenameProperties" value="true" />
  <Var name="KeepPublicApi" value="true" /> <!-- default global; can override per-module -->


  <!-- Module 2: library DLL -->
  <Module file="$(InPath)\Tools.dll"
          out="$(OutPath)\Tools.dll"
          keepPublicApi="true">  <!-- keep public API stable for consumers -->
    <!-- Example: skip an entire namespace -->
    <!-- <SkipNamespace name="MyLib.ApiPublic" /> -->
    <SkipType name="*AnonymousType*" skipProperties="true" skipMethods="true" skipFields="true" skipEvents="true" />
  </Module>

  <!-- Optional: include other DLLs if they are referenced and you want them obfuscated too -->
  <!-- <Module file="$(InPath)\ThirdParty.Helper.dll" out="$(OutPath)\ThirdParty.Helper.dll" /> -->

  <!-- Logging / xml output file (optional) -->
  <LogFile>obfuscar-log.txt</LogFile>
</Obfuscator>
