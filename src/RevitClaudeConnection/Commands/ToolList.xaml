<Window x:Class="RevitClaudeConnector.Commands.ToolList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               WindowStartupLocation="CenterScreen"
             Title="RevitClaudeConnector Tools" Height="500" Width="800">
    <DockPanel Margin="10">
        <!-- Search bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="SearchBox" Width="200" 
                     VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged"  />
        </StackPanel>

        <!-- Table -->
        <DataGrid x:Name="ToolGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  ItemsSource="{Binding FilteredTools}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding ToolSchema.Name}" Width="2*"/>
                <DataGridTemplateColumn Header="Description" Width="4*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ToolSchema.Description}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top"
                               Padding="4,2,4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Action" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View Schema" 
                                    Click="ViewSchema_Click" 
                                    Tag="{Binding}" 
                                    Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
