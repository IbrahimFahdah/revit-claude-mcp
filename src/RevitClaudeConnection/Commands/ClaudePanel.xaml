<UserControl x:Class="RevitClaudeConnector.Commands.ClaudePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <Grid x:Name="RootGrid">
        <Border x:Name="ClaudeHost"
                Background="Black"
                BorderThickness="0" />
